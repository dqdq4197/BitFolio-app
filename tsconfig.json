{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "baseUrl": "./",
    "paths": {
      "/*": ["./src/*"]
    },
    "lib": ["dom", "esnext"],
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true
  },
  "extends": "expo/tsconfig.base"
}
