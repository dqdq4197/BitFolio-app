{
  "expo": {
    "name": "bitfolio",
    "slug": "bitfolio",
    "version": "1.0.15",
    "orientation": "portrait",
    "icon": "./assets/bitfolio_icon.png",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/6d4899c7-afc3-472c-8299-a027f908ef57"
    },
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bitfolio.cryptocurrencies.ios",
      "associatedDomains": [
        "applinks:bitfolio.page.link"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212"
      },
      "versionCode": 1,
      "package": "com.bitfolio.cryptocurrencies.ios"
    },
    "web": {
      "favicon": "./assets/splash.png"
    },
    "description": "cryptocurrencies",
    "extra": {
      "eas": {
        "projectId": "6d4899c7-afc3-472c-8299-a027f908ef57"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121212",
          "image": "./assets/splash.png",
          "dark": {
            "image": "./assets/splash.png",
            "backgroundColor": "#121212"
          },
          "imageWidth": 400,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-localization",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ]
  }
}
